#include <iostream>
using namespace std;
int main(){
int n, x = 0, y = 1, z;
cout << "Enterthe number of terms:\t";
cin >> n;
if (n==0)
{
cout << "Invalid Input\n";
} else {
if (n >= 1) cout << x << "";
if (n >= 2) cout << y << "";
for(int i = 2; i < n; ++i){
z = x + y;
cout << z << "";
x = y;
y = z;
}
}
cout << "\n";
return 0;
}