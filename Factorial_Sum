#include <iostream>
using namespace std;
int main(){
double totalSum = 0.0;
for(int i = 1; i <= 7; i++){
double factorial = 1.0;
for(int j = 1; j <= i; j++){
factorial *= j;
}
totalSum += (i/factorial);
cout << "Term " << i << ":" << i << "/" << i << "! = " << (i/factorial) << endl;
}
cout << "The sum of the firstseven termsis:" << totalSum << endl;
return 0;
}
