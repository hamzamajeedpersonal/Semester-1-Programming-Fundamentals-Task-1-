#include <iostream>
using namespace std;
int main(){
int n,reversedNumber = 0,remainder;
cout << "Enter Number:";
cin >> n;
int original = n;
while(n != 0){
remainder = n % 10;
reversedNumber = reversedNumber * 10 + remainder;
n /= 10;
}
cout << "Original Number:" << original << "\n";
cout << "Reversed Number:" << reversedNumber << "\n";
return 0;
}
